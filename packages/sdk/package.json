{
  "name": "@sentinel/sdk",
  "version": "0.1.0",
  "description": "Official SDK for the Sentinel A2MCP trust layer",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
