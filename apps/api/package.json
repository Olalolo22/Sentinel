{
  "name": "@sentinel/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=../../.env --import tsx/esm --watch src/index.ts",
    "build": "tsc -p tsconfig.json && node -e \"require('fs').cpSync('src/db/migrations','dist/db/migrations',{recursive:true})\"",
    "start": "node dist/index.js",
    "test": "vitest run",
    "migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@hono/node-server": "^1.13.7",
    "@sentinel/rules": "*",
    "@x402/evm": "^2.19.0",
    "@x402/hono": "^2.19.0",
    "fast-json-stable-stringify": "^2.1.0",
    "groq-sdk": "^1.3.0",
    "hono": "^4.6.14",
    "ioredis": "^5.4.2",
    "node-html-parser": "^7.0.1",
    "pg": "^8.13.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
