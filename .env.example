# ─── Sentinel API — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in the values for local development.

# ── Required ──────────────────────────────────────────────────────────────────

# Gemini API key (Stage 2 LLM Judge)
GEMINI_API_KEY=

# PostgreSQL connection string (Railway provides this automatically)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sentinel

# ── Recommended ───────────────────────────────────────────────────────────────

# Upstash Redis URL (enables verdict caching + rate limiting)
REDIS_URL=

# Ed25519 signing keypair for trust receipts.
# If omitted, an ephemeral keypair is generated on startup (not persistent).
# Generate with: node -e "const c=require('crypto'); const k=c.generateKeyPairSync('ed25519'); console.log(k.privateKey.export({type:'pkcs8',format:'pem'}).toString())"
SENTINEL_SIGNING_KEY=

# Port (Railway sets this automatically)
PORT=3000

# ── x402 Payment (OKX A2MCP listing) ─────────────────────────────────────────
# Leave PAYMENT_ENABLED unset (or set to "false") for free/demo mode.
# Set to "true" to enforce x402 payment on /v1/scan and /v1/scan/batch.

# Enable x402 pay-per-call enforcement
PAYMENT_ENABLED=false

# Your EVM wallet address on X Layer that receives USDT payments
# Required when PAYMENT_ENABLED=true
SENTINEL_PAYMENT_ADDRESS=

# Optional: custom x402 facilitator URL
# Defaults to Coinbase's public facilitator if unset.
# Set to OKX's facilitator endpoint for OKX A2MCP listing.
X402_FACILITATOR_URL=
